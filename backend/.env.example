APP_NAME=HDBarber
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Madrid

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Para Docker: DB_HOST=db / DB_USERNAME=hdbarber / DB_PASSWORD=hdbarber
# Para instalación local: DB_HOST=127.0.0.1 / DB_USERNAME=root
DB_HOST=db
DB_PORT=3306
DB_DATABASE=hdbarber
DB_USERNAME=hdbarber
DB_PASSWORD=hdbarber

BROADCAST_DRIVER=log
CACHE_STORE=file
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SPA_URL=http://localhost:5173

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Para Docker usa MailHog: MAIL_MAILER=smtp / MAIL_HOST=mailhog / MAIL_PORT=1025
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@hdbarber.test"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=eur

THROTTLE_LOGIN_MAX=5
THROTTLE_LOGIN_DECAY=1
